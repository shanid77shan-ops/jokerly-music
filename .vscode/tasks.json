{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Deploy to Vercel Production",
			"type": "shell",
			"command": "vercel",
			"args": [
				"--prod"
			],
			"isBackground": false
		},
		{
			"label": "Local Next Build",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Local Next Build After Fix",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Local Next Build After Search Fix",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Dev server (device / HTTPS)",
			"type": "shell",
			"command": "pnpm",
			"args": ["run", "dev:device"],
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": { "regexp": "^$" },
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Starting",
					"endsPattern": "Ready|Local:"
				}
			}
		},
		{
			"label": "Android: install debug APK",
			"type": "shell",
			"command": "pnpm",
			"args": ["run", "android:install-debug"],
			"isBackground": false
		},
		{
			"label": "Deploy to Vercel Production After Fixes",
			"type": "shell",
			"command": "vercel",
			"args": [
				"--prod"
			],
			"isBackground": false
		}
	]
}